{
  "routes": [
    { "handle": "filesystem" },

    { "src": "^/admin$", "dest": "/admin/index.html" },
    { "src": "^/admin/(.*)", "dest": "/admin/$1" },

    { "src": "^/api/create$", "dest": "/api/create.js" },
    { "src": "^/api/stats$", "dest": "/api/stats.js" },

    { "src": "^/(.*)/(.*)", "dest": "/api/redirect.js" }
  ]
}
